<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:paddingTop="16dp">
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back1"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Back" />

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnBack" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnBack"
        app:layout_constraintVertical_bias="1.0"
        app:layout_constraintWidth_max="600dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp"
            android:paddingTop="24dp"
            android:paddingStart="25dp"
            android:paddingEnd="25dp">

            <LinearLayout
                android:id="@+id/rowGeneral"
                style="@style/SettingsRowStyle">

                <TextView
                    style="@style/SettingsTextStyle"
                    android:text="General Settings" />

                <ImageView
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_rback" />
            </LinearLayout>

            <View style="@style/SettingsDividerStyle" />

            <LinearLayout
                android:id="@+id/rowNotifications"
                style="@style/SettingsRowStyle">

                <TextView
                    style="@style/SettingsTextStyle"
                    android:text="Notification Settings" />

                <ImageView
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_rback" />
            </LinearLayout>

            <View style="@style/SettingsDividerStyle" />

            <LinearLayout
                android:id="@+id/rowDarkMode"
                style="@style/SettingsRowStyle">

                <TextView
                    style="@style/SettingsTextStyle"
                    android:text="Light Mode" />

                <ImageView
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_rback" />
            </LinearLayout>

            <View style="@style/SettingsDividerStyle" />

            <LinearLayout
                android:id="@+id/rowCalendar"
                style="@style/SettingsRowStyle">

                <TextView
                    style="@style/SettingsTextStyle"
                    android:text="Calendar" />

                <ImageView
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_rback" />
            </LinearLayout>

            <View style="@style/SettingsDividerStyle" />

            <LinearLayout
                android:id="@+id/rowOffline"
                style="@style/SettingsRowStyle">

                <TextView
                    style="@style/SettingsTextStyle"
                    android:text="Offline" />

                <ImageView
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_rback" />
            </LinearLayout>

            <View style="@style/SettingsDividerStyle" />

            <LinearLayout
                android:id="@+id/rowPrivacy"
                style="@style/SettingsRowStyle">

                <TextView
                    style="@style/SettingsTextStyle"
                    android:text="Privacy Policy"
                    android:textColor="#CCCCCC" />

                <ImageView
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_rback" />
            </LinearLayout>

            <View style="@style/SettingsDividerStyle" />

            <LinearLayout
                android:id="@+id/rowTerms"
                style="@style/SettingsRowStyle">

                <TextView
                    style="@style/SettingsTextStyle"
                    android:text="Terms of Service"
                    android:textColor="#CCCCCC" />

                <ImageView
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_rback" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>